#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <math.h>

typedef long long ll;

int is_lucky(ll n) {
    if (n <= 0) return 0;
    while (n > 0) {
        if ((n % 10) % 2 == 0) return 0;
        n /= 10;
    }
    return 1;
}

ll string_to_ll(char *s) {
    ll res = 0;
    for (int i = 0; s[i]; i++) res = res * 10 + (s[i] - '0');
    return res;
}

void solve() {
    char s[25];
    if (scanf("%s", s) == EOF) return;
    ll n = string_to_ll(s);
    
    int len = strlen(s);
    int first_even = -1;
    for (int i = 0; i < len; i++) {
        if ((s[i] - '0') % 2 == 0) {
            first_even = i;
            break;
        }
    }

    if (first_even == -1) {
        printf("%lld\n", n);
        return;
    }

   
    char lower_s[25];
    strcpy(lower_s, s);
    lower_s[first_even]--; // Make it odd (e.g., 6->5, 2->1)
    for (int i = first_even + 1; i < len; i++) lower_s[i] = '9';
    
  
    ll lower_v;
    if (lower_s[first_even] < '0') {
        // Simple fallback for complex borrow: search downwards
        lower_v = string_to_ll(s);
        while (!is_lucky(lower_v)) lower_v--;
    } else {
        lower_v = string_to_ll(lower_s);
    }

   
    char higher_s[25];
    strcpy(higher_s, s);
    higher_s[first_even]++; // Make it odd (e.g., 6->7, 0->1)
    for (int i = first_even + 1; i < len; i++) higher_s[i] = '1';
    ll higher_v = string_to_ll(higher_s);

    if (llabs(n - lower_v) <= llabs(n - higher_v)) {
        printf("%lld\n", lower_v);
    } else {
        printf("%lld\n", higher_v);
    }
}

int main() {
    solve();
    return 0;
}
