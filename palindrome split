#include <stdio.h>
#include <string.h>


void solve() {
   
    char s[100005]; 
    if (scanf("%s", s) != 1) return;
    
    
    int count[26] = {0};
    for (int i = 0; s[i] != '\0'; i++) {
        count[s[i] - 'a']++;
    }
    
    int total_palindromes = 0;
    for (int i = 0; i < 26; i++) {    // For each character, the number of pairs is floor(count / 2)

        total_palindromes += count[i] / 2;
    }
    
    printf("%d\n", total_palindromes);
}

int main() {
    int t;
   
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
