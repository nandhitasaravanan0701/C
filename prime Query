#include <stdio.h>

#define MAX 100005

int a[MAX];
int pref0[MAX], pref1[MAX];

void solve() {
    int n;
    if (scanf("%d", &n) != 1) return;

    for (int i = 1; i <= n; i++) {
        scanf("%d", &a[i]);
        pref0[i] = pref0[i - 1] + (a[i] == 0);
        pref1[i] = pref1[i - 1] + (a[i] == 1);
    }

    int q;
    scanf("%d", &q);
    while (q--) {
        int l, r;
        scanf("%d %d", &l, &r);

        long long len = r - l + 1;
        long long total_pairs = (len * (len - 1)) / 2;

        long long c0 = pref0[r] - pref0[l - 1];
        long long c1 = pref1[r] - pref1[l - 1];

        
        long long bad_pairs = (c0 * (c0 - 1)) / 2 + (c0 * c1);

        printf("%lld\n", total_pairs - bad_pairs);
    }
}

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
