#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct {
    int id;
    int pos;
    int health;
    char dir;
} Robot;

// Comparator to sort robots by their physical position
int compareRobots(const void* a, const void* b) {
    return ((Robot*)a)->pos - ((Robot*)b)->pos;
}

int* survivedRobotsHealths(int* positions, int positionsSize, int* healths, int healthsSize, char* directions, int* returnSize) {
    int n = positionsSize;
    Robot* robots = (Robot*)malloc(n * sizeof(Robot));
    for (int i = 0; i < n; i++) {
        robots[i].id = i;
        robots[i].pos = positions[i];
        robots[i].health = healths[i];
        robots[i].dir = directions[i];
    }

        qsort(robots, n, sizeof(Robot), compareRobots);

    
    int* stack = (int*)malloc(n * sizeof(int));
    int top = -1;

    for (int i = 0; i < n; i++) {
        if (robots[i].dir == 'R') {
            stack[++top] = i;
        } else {
           
            while (top >= 0 && robots[i].health > 0) {
                int rIdx = stack[top];
                if (robots[rIdx].health < robots[i].health) {
                    // Left robot wins
                    robots[rIdx].health = 0;
                    robots[i].health -= 1;
                    top--;
                } else if (robots[rIdx].health > robots[i].health) {
                    // Right robot wins
                    robots[rIdx].health -= 1;
                    robots[i].health = 0;
                } else {
                    // Both destroyed
                    robots[rIdx].health = 0;
                    robots[i].health = 0;
                    top--;
                }
            }
        }
    }

   
    int* result = (int*)malloc(n * sizeof(int));
    int count = 0;
    
    
    int* finalHealths = (int*)calloc(n, sizeof(int));
    for (int i = 0; i < n; i++) {
        if (robots[i].health > 0) {
            finalHealths[robots[i].id] = robots[i].health;
        }
    }

    for (int i = 0; i < n; i++) {
        if (finalHealths[i] > 0) {
            result[count++] = finalHealths[i];
        }
    }

    *returnSize = count;
    free(robots);
    free(stack);
    free(finalHealths);
    return result;
}
