#include <stdio.h>

void solve() {
    int n;
    if (scanf("%d", &n) != 1) return;

    long long sumA = 0;
    long long maxA = 0;
    long long a[n];

    for (int i = 0; i < n; i++) {
        scanf("%lld", &a[i]);
        sumA += a[i];
        if (a[i] > maxA) {
            maxA = a[i];
        }
    }

   
    if (n == 1) {
        if (a[0] == 0) printf("0\n");
        else printf("-1\n");
        return;
    }

    
    if (sumA % (n - 1) != 0) {
        printf("-1\n");
        return;
    }

    long long k = sumA / (n - 1);

    
    if (k < maxA) {
        printf("-1\n");
    } else {
        printf("%lld\n", k);
    }
}

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
