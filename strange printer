#include <string.h>
#include <math.h>

#define MIN(a, b) ((a) < (b) ? (a) : (b))

int strangePrinter(char* s) {
    int n = strlen(s);
    if (n == 0) return 0;

    // dp[i][j] = min turns to print substring s[i...j]
    int dp[101][101];

    // Every single character takes 1 turn
    for (int i = 0; i < n; i++) dp[i][i] = 1;

    // Fill the table for intervals of length 2 up to n
    for (int len = 2; len <= n; len++) {
        for (int i = 0; i <= n - len; i++) {
            int j = i + len - 1;
            
            // Worst case: print the first char then the rest
            dp[i][j] = 1 + dp[i + 1][j];

            // Try to find a split point 'k' to optimize
            for (int k = i + 1; k <= j; k++) {
                if (s[i] == s[k]) {
                    // If s[i] matches s[k], we can combine their turns
                    // The turn used for s[i] can cover s[k] as well
                    int total = dp[i][k - 1] + (k + 1 <= j ? dp[k + 1][j] : 0);
                    dp[i][j] = MIN(dp[i][j], total);
                }
            }
        }
    }

    return dp[0][n - 1];
}
