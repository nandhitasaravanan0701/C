#include <stdio.h>
#include <stdlib.h>
#include <string.h>

void solve(int row, int n, int* cols, int* diag1, int* diag2, char** board, 
           char*** *results, int* returnSize) {
    if (row == n) {
       
        *results = realloc(*results, sizeof(char**) * (*returnSize + 1));
        (*results)[*returnSize] = malloc(sizeof(char*) * n);
        for (int i = 0; i < n; i++) {
            (*results)[*returnSize][i] = strdup(board[i]);
        }
        (*returnSize)++;
        return;
    }

    for (int col = 0; col < n; col++) {
        
        if (!cols[col] && !diag1[row - col + n - 1] && !diag2[row + col]) {
            board[row][col] = 'Q';
            cols[col] = diag1[row - col + n - 1] = diag2[row + col] = 1;

            solve(row + 1, n, cols, diag1, diag2, board, results, returnSize);

           
            board[row][col] = '.';
            cols[col] = diag1[row - col + n - 1] = diag2[row + col] = 0;
        }
    }
}

char*** solveNQueens(int n, int* returnSize, int** returnColumnSizes) {
    *returnSize = 0;
   
    char*** results = NULL;
    
    char** board = malloc(sizeof(char*) * n);
    for (int i = 0; i < n; i++) {
        board[i] = malloc(n + 1);
        memset(board[i], '.', n);
        board[i][n] = '\0';
    }

    int* cols = calloc(n, sizeof(int));
    int* diag1 = calloc(2 * n, sizeof(int));
    int* diag2 = calloc(2 * n, sizeof(int));

   
    solve(0, n, cols, diag1, diag2, board, &results, returnSize);

    *returnColumnSizes = malloc(sizeof(int) * (*returnSize));
    for (int i = 0; i < *returnSize; i++) {
        (*returnColumnSizes)[i] = n;
    }

    
    for (int i = 0; i < n; i++) free(board[i]);
    free(board);
    free(cols);
    free(diag1);
    free(diag2);

    return results;
}
