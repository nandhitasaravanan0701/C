#include <stdio.h>

#define MOD 1000000007
#define MAX_VAL 100001


int gcd(int a, int b) {
    while (b) {
        a %= b;
        int temp = a;
        a = b;
        b = temp;
    }
    return a;
}

void solve() {
    int n;
    if (scanf("%d", &n) != 1) return;
    
    int a[n];
    int max_a = 0;
    for (int i = 0; i < n; i++) {
        scanf("%d", &a[i]);
        if (a[i] > max_a) max_a = a[i];
    }

   
    long long dp[MAX_VAL] = {0};
    long long total_ans = 0;

    for (int i = 0; i < n; i++) {
        int current = a[i];
        long long current_ways = 1; // The single element [current]

       
        for (int v = 1; v <= max_a; v++) {
            if (dp[v] > 0 && gcd(v, current) == 1) {
                current_ways = (current_ways + dp[v]) % MOD;
            }
        }

       
        dp[current] = (dp[current] + current_ways) % MOD;
    }

    
    long long final_count = 0;
    for (int v = 1; v <= max_a; v++) {
        final_count = (final_count + dp[v]) % MOD;
    }

    printf("%lld\n", final_count);
}

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
