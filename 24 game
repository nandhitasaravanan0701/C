#include <stdbool.h>
#include <math.h>

bool dfs(double* a, int n) {
    if (n == 1) return fabs(a[0] - 24) < 1e-6;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (i == j) continue;

            double next_a[4];
            int m = 0;
            for (int k = 0; k < n; k++) {
                if (k != i && k != j) next_a[m++] = a[k];
            }

            double ops[6] = {
                a[i] + a[j], a[i] - a[j], a[j] - a[i], 
                a[i] * a[j], 
                a[j] != 0 ? a[i] / a[j] : 0, 
                a[i] != 0 ? a[j] / a[i] : 0
            };

            for (int k = 0; k < 6; k++) {
                if (k >= 4 && ((k == 4 && a[j] == 0) || (k == 5 && a[i] == 0))) continue;
                next_a[m] = ops[k];
                if (dfs(next_a, n - 1)) return true;
            }
        }
    }
    return false;
}

bool judgePoint24(int* cards, int cardsSize) {
    double a[4];
    for (int i = 0; i < 4; i++) a[i] = (double)cards[i];
    return dfs(a, 4);
}
